# Copy to `.env` and adjust. Pydantic-Settings (see app/config.py) reads
# this file at startup; environment variables override file values.

# REQUIRED
# Absolute path to the directory holding the vault's `.md` files. `~` is
# expanded. The server treats every file under this path as the source of
# truth and never writes anywhere else.
VAULT_DIR=/path/to/your/vault

# OPTIONAL — file/cache layout
# Where the binary Yjs cache lives. Keeps CRDT item IDs stable across the
# grace-period eviction and server restarts so reconnecting clients don't
# merge the same characters in twice. `~` is expanded.
# Default: ~/.cache/mdshards
# CACHE_DIR=~/.local/share/mdshards

# NOTE — static frontend serving is NOT configured here. When a prebuilt
# bundle is present in a `static/` dir next to the `app/` package (the
# single-container image copies Vite's `dist/` there), uvicorn serves it
# automatically. In local dev there's no such dir and Vite serves the bundle.

# OPTIONAL — lifecycle
# Seconds the in-memory Doc lingers after the last client disconnects.
# Clients send periodic awareness heartbeats so a backgrounded-but-alive
# tab keeps the Doc resident. Increase for flaky networks, decrease to
# free memory sooner.
# Default: 30
# GRACE_PERIOD_SECONDS=30

# OPTIONAL — bind address (process-internal)
# Interface + port uvicorn binds to. These are NOT the public-facing host;
# use BASE_URL for a sub-path mount behind a reverse proxy.
# Default: 127.0.0.1:8000
# HOST=127.0.0.1
# PORT=8000

# OPTIONAL — reverse-proxy / sub-path deploy
# Set when the app is served from a sub-path of the public origin, e.g.
# `https://notes.example.com/wiki/`. Wired into FastAPI's `root_path` for
# OpenAPI doc URLs and `request.url_for(...)`, and surfaced to the
# frontend bundle via `/api/config`'s `homePath` field — used solely as
# React Router's basename so internal navigation writes the right path
# to the URL bar. The proxy is still responsible for forwarding API,
# WS, asset, and SPA-shell requests to the backend (the frontend bundle
# itself emits all URLs as if it were mounted at root).
# Format: leading slash, no trailing slash. Empty = mounted at root.
# BASE_URL=/wiki

# NOTE — customizing the index.md seed is NOT an env var. Drop (or bind-mount)
# a markdown file at ~/.mdshards/index.md and it seeds <vault>/index.md on first
# access; absent, a built-in default is used. It's a fixed path on purpose — an
# env-var path would let the setting read an arbitrary file off the filesystem.
